# Eventra Environment Configuration

# Database
DATABASE_URL=postgresql://localhost:5432/eventra

# Server
PORT=3008
HOST=0.0.0.0

# Redis (for BullMQ background worker)
REDIS_HOST=localhost
REDIS_PORT=6379

# Encryption (for storing API keys securely)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=
