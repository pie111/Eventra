{
    "name": "eventra",
    "version": "0.1.0",
    "private": true,
    "description": "Stateful, event-driven LLM agent system",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "dev:worker": "tsx watch src/worker/index.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/index.js",
        "start:worker": "node dist/worker/index.js",
        "lint": "tsc --noEmit",
        "clean": "rm -rf dist *.tsbuildinfo",
        "db:push": "drizzle-kit push",
        "db:generate": "drizzle-kit generate",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@ai-sdk/anthropic": "^1.0.0",
        "@ai-sdk/google": "^1.0.0",
        "@ai-sdk/mistral": "^1.0.0",
        "@ai-sdk/openai": "^1.0.0",
        "@fastify/cors": "^11.0.0",
        "@fastify/swagger": "^9.0.0",
        "@fastify/swagger-ui": "^5.0.0",
        "@langchain/anthropic": "^1.3.0",
        "@langchain/core": "^1.1.29",
        "@langchain/google-genai": "^1.0.0",
        "@langchain/langgraph": "^1.2.0",
        "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
        "@langchain/mistralai": "^1.0.0",
        "@langchain/openai": "^1.2.0",
        "ai": "^4.0.0",
        "bullmq": "^5.70.1",
        "dotenv": "^16.4.5",
        "drizzle-orm": "^0.38.0",
        "fastify": "^5.0.0",
        "ioredis": "^5.10.0",
        "pino-pretty": "^13.1.3",
        "postgres": "^3.4.0",
        "zod": "^3.23.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "drizzle-kit": "^0.30.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0"
    },
    "engines": {
        "node": ">=20.0.0"
    }
}
